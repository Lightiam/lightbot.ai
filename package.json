    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^4.9.5"
  }
